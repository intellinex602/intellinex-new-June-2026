# Intellinex Technologies - Environment Variables
# Copy this file to .env.local for local development

# ─────────────────────────────────────────────────────────
# FRONTEND (Vite)
# ─────────────────────────────────────────────────────────

# Backend API URL — set this in Vercel project settings once your backend is live.
# Leave empty to use local fallback responses in chat/contact form.
VITE_API_URL=

# Example for production (when backend is deployed):
# VITE_API_URL=https://api.intellinex.tech

# ─────────────────────────────────────────────────────────
# VERCEL SERVERLESS FUNCTIONS (api/contact.js)
# Set these in your Vercel project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────

# Your Resend API key — get one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# The email address that receives new contact form submissions
CONTACT_EMAIL_TO=sales.services@intellinex.in

# ─────────────────────────────────────────────────────────
# BACKEND (FastAPI) — set in backend/.env, not here
# ─────────────────────────────────────────────────────────

# DATABASE_URL=postgresql+psycopg://user:password@host:5432/intellinex
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_EMAIL_TO=sales.services@intellinex.in
# GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxx
